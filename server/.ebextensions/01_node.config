# Amazon Linux 2023 Node.js uses Procfile (web: npm run start:prod), not NodeCommand.
option_settings:
  aws:elasticbeanstalk:application:environment:
    NODE_ENV: production
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /api/health
    Port: "8080"
    Protocol: HTTP

container_commands:
  01_build:
    command: "npm run build"
    cwd: /var/app/staging

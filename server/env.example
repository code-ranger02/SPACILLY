# Copy to `server/env` for local dev. On AWS Elastic Beanstalk, set these in Environment properties
# (see deploy/aws/environment.properties.example).

PORT=5000
NODE_ENV=production
HOST=0.0.0.0
APP_NAME=Spacilly

CLIENT_URL=https://www.spacilly.com
SERVER_URL=https://api.spacilly.com
ALLOWED_ORIGINS=https://www.spacilly.com,https://spacilly.com

# MongoDB Atlas
MONGODB_URI=mongodb+srv://spacilly:<db_password>@spacilly.phhthbt.mongodb.net/SpacillyDB?retryWrites=true&w=majority&appName=spacilly

JWT_SECRET=
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.spacilly.com/api/auth/google/callback

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@spacilly.com
SMTP_USER=
SMTP_PASS=

MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CALLBACK_URL=https://api.spacilly.com/api/payments/momo/callback

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_RATE_REFRESH_MS=300000

OPENROUTESERVICE_API_KEY=

MICROBLINK_LICENSE_KEY=
MICROBLINK_SECRET=
# If secret contains + or =, use base64 in the EB console:
# MICROBLINK_SECRET_B64=
MICROBLINK_REGION=EU

PAYMENT_SECRETS_MASTER_KEY=

# Optional
REDIS_URL=
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@spacilly.com

# No custom domain yet — use AWS default URLs
# Replace placeholders after you create CloudFront distributions and EB environment.

NODE_ENV=production
HOST=0.0.0.0
APP_NAME=Spacilly

# Frontend CloudFront URL (https://dXXXXXXXXXX.cloudfront.net)
CLIENT_URL=https://YOUR_FRONTEND_CLOUDFRONT.cloudfront.net

# API URL — use API CloudFront URL (recommended) OR EB URL
# Recommended (HTTPS): https://YOUR_API_CLOUDFRONT.cloudfront.net
# Direct EB (HTTP only): http://spacilly-api-prod.eba-XXXXXX.us-east-1.elasticbeanstalk.com
SERVER_URL=https://YOUR_API_CLOUDFRONT.cloudfront.net

# Must match CLIENT_URL (comma-separate if you add more origins later)
ALLOWED_ORIGINS=https://YOUR_FRONTEND_CLOUDFRONT.cloudfront.net

# --- Database (MongoDB Atlas — external, not AWS) ---
MONGODB_URI=mongodb+srv://spacilly:<password>@spacilly.phhthbt.mongodb.net/SpacillyDB?retryWrites=true&w=majority&appName=spacilly

# --- Auth ---
JWT_SECRET=GENERATE_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://YOUR_API_CLOUDFRONT.cloudfront.net/api/auth/google/callback

# --- Email ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@your-temp-mail.com

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- AI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Payments: Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Payments: Flutterwave ---
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=
FLW_SECRET_HASH=

# --- Payments: MTN MoMo ---
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_CALLBACK_URL=https://YOUR_API_CLOUDFRONT.cloudfront.net/api/payments/momo/callback

# --- Exchange rates ---
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6
EXCHANGE_RATE_REFRESH_MS=300000

# --- Microblink KYC ---
MICROBLINK_LICENSE_KEY=
MICROBLINK_SECRET=
MICROBLINK_REGION=EU

# --- Payment security ---
PAYMENT_SECRETS_MASTER_KEY=

# --- Optional ---
REDIS_URL=
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@example.com

PLATFORM_FEE_PERCENT=5
DEFAULT_CURRENCY=USD
